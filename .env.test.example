# PostgreSQL
TEST_POSTGRES_URL=postgresql+psycopg2://testuser:testpass@localhost:5432/testdb

# DynamoDB (LocalStack)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
